APP_NAME=""
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://localhost:8000

# ==========================================
# 🔐 SECURITY & ADMIN SETTINGS
# ==========================================
# Set your custom admin panel URL (e.g., my-secret-panel). Default: admin
FILAMENT_ADMIN_PATH=admin

# Default credentials created when running Migrations/Seeders
ADMIN_NAME=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ==========================================
# 🌍 INTERNATIONALIZATION (i18n)
# ==========================================
# Choose your base fallback language (e.g., en, fr, pt, es)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ==========================================
# 🗄️ DATABASE & DRIVERS
# ==========================================
DB_CONNECTION=mysql

DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessions and Cache are handled internally by the database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
