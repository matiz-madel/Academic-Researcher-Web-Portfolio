APP_NAME="Your Name"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ==========================================
# 🔐 SECURITY & ADMIN SETTINGS
# ==========================================
# Set your custom admin panel URL (e.g., my-secret-admin). Default: admin
FILAMENT_ADMIN_PATH=admin

# Default credentials created when running Migrations/Seeders
ADMIN_NAME="Admin Name"
ADMIN_EMAIL="name@example.com"
ADMIN_PASSWORD="YourStrongPasswordHere"

# ==========================================
# 🌍 INTERNATIONALIZATION (i18n)
# ==========================================
# Choose your base fallback language (e.g., en, fr, pt, es)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ==========================================
# 🗄️ DATABASE & DRIVERS (Zero-Config Setup)
# ==========================================
# SQLite for a plug-and-play local installation
DB_CONNECTION=sqlite

# Sessions and Cache are handled internally by the database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
